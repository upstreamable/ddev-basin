{
  "name": "upstreamable/ddev-basin",
  "description": "",
  "license": "GPL-3.0-or-later",
  "minimum-stability": "dev",
  "prefer-stable": false,
  "authors": [
    { "name": "Rodrigo Aguilera", "email": "hi@rodrigoaguilera.net" }
  ],
  "bin": [
    "bin/basin.php"
  ],
  "require": {
    "composer-runtime-api": "^2.2",
    "symfony/console": "^8 || ^7 || ^6",
    "symfony/finder": "^8",
    "symfony/process": "^8 || ^7 || ^6",
    "symfony/yaml": "^8 || ^7 || ^6 || ^5"
  },
  "autoload": {
    "psr-4": {
      "Basin\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
}
